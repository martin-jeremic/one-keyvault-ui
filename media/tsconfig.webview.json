{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2020"],
    "rootDir": "./secrets-src",
    "outDir": "./secrets-dist",
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": ["./secrets-src/**/*.ts", "./secrets-src/**/*.d.ts"]
}
